# dubyduby — Korean dub configuration

# STT engine selector — which speech-to-text backend dub.sh uses.
#   soniox (default): async batch, 200min/month free
#   60db:             single POST to https://api.60db.ai/stt
# DUBYDUBY_STT=soniox

# Soniox API key (STT — Speech-to-Text)
# Sign up at https://soniox.com (Free 200min/month, $0.02/min after)
SONIOX_API_KEY=your_soniox_key_here

# 60db API key (alternative STT — used when DUBYDUBY_STT=60db)
# Docs: https://docs.60db.ai/api-reference/stt/speech-to-text
# Note: /stt caps uploads at 10MB / 1h; long sources are auto re-encoded to fit.
SIXTYDB_API_KEY=your_60db_key_here
# SIXTYDB_BASE_URL=https://api.60db.ai   # override for self-hosted/testing
# DUBYDUBY_STT_LANG=en                    # source language; "auto" to detect
